    /// <summary>
    /// 具體的測試類別範例
    /// </summary>
    public class MemberApiTests : ApiTestBase
    {
        public MemberApiTests(ApiTestFixture fixture) : base(fixture)
        {
        }

        [Fact]
        public async Task GetMembers_ShouldReturnSuccessStatusCode()
        {
            // Arrange
            var request = new HttpRequestMessage(HttpMethod.Get, "/api/v1/members");

            // Act
            var response = await HttpClient.SendAsync(request);

            // Assert
            Assert.True(response.IsSuccessStatusCode);
        }

        [Fact]
        public async Task CreateMember_WithValidData_ShouldReturn201Created()
        {
            // Arrange
            var request = new
            {
                email = "test@example.com",
                name = "Test Member"
            };

            // Act
            var response = await HttpClient.PostAsJsonAsync("/api/v1/members", request);

            // Assert
            Assert.Equal(System.Net.HttpStatusCode.Created, response.StatusCode);
        }
    }
