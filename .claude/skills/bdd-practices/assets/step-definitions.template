        #region Then Steps - 驗證結果

        [Then("API 回應 (.*)")]
        public void ThenApiReturnsStatusCode(int statusCode)
        {
            Assert.NotNull(_lastResponse);
            Assert.Equal((HttpStatusCode)statusCode, _lastResponse.StatusCode);
        }

        [Then("API 回應 (\\d+) (.*)")]
        public void ThenApiReturnsStatusCodeWithName(int statusCode, string statusName)
        {
            // statusName 可用於偵錯或日誌
            ThenApiReturnsStatusCode(statusCode);
        }

        [Then("回應中包含建立的會員資訊")]
        public async Task ThenResponseContainsMemberInfo()
        {
            Assert.NotNull(_lastResponse);
            var content = await _lastResponse.Content.ReadAsAsync<dynamic>();

            Assert.NotNull(content.id);
            Assert.NotNull(content.email);
            Assert.NotNull(content.name);
        }

        [Then("錯誤訊息指明 Email 已存在")]
        public async Task ThenErrorMessageIndicatesDuplicateEmail()
        {
            var content = await _lastResponse.Content.ReadAsStringAsync();
            Assert.Contains("email", content, StringComparison.OrdinalIgnoreCase);
            Assert.Contains("exists", content, StringComparison.OrdinalIgnoreCase);
        }

        [Then("回應的 (\\w+) 欄位等於 \"([^\"]*)\"")]
        public async Task ThenResponseFieldEqualsValue(string fieldName, string expectedValue)
        {
            var content = await _lastResponse.Content.ReadAsAsync<dynamic>();
            var actualValue = content[fieldName]?.ToString();

            Assert.Equal(expectedValue, actualValue);
        }

