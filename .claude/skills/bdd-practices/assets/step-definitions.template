        #region 輔助方法

        /// <summary>
        /// 將 Reqnroll Table 轉換為鍵值對
        /// </summary>
        private Dictionary<string, string> TableToDictionary(TableRow row)
        {
            var dict = new Dictionary<string, string>();
            foreach (var key in row.Keys)
            {
                dict[key] = row[key];
            }
            return dict;
        }

        /// <summary>
        /// 設定 HTTP 標頭（用於認證等）
        /// </summary>
        private void SetAuthorizationHeader(string token)
        {
            _fixture.HttpClient.DefaultRequestHeaders.Clear();
            _fixture.HttpClient.DefaultRequestHeaders.Add("Authorization", $"Bearer {token}");
        }

        #endregion
